# ─── Shelbynet (Aptos) ───────────────────────────────────────────────────────
# Move module deployer address (set after running contracts/deploy.sh)
VITE_MODULE_ADDR=0xYOUR_DEPLOYER_ADDRESS

# Shelbynet node URL
VITE_APTOS_NODE_URL=https://api.shelbynet.shelby.network/v1

# Aptos indexer GraphQL endpoint (for live reads)
VITE_APTOS_INDEXER_URL=https://indexer.shelbynet.shelby.network/v1/graphql

# ─── Shelby Storage ──────────────────────────────────────────────────────────
# Get your API key from https://app.shelby.network/dashboard
VITE_SHELBY_API_KEY=sk_shelby_YOUR_KEY_HERE
VITE_SHELBY_API_URL=https://api.shelby.network

# ─── AI Image Generation ─────────────────────────────────────────────────────
# Replicate API key for Flux image generation — https://replicate.com
# Leave blank to use demo/placeholder images
VITE_REPLICATE_API_KEY=r8_YOUR_REPLICATE_KEY_HERE
